# Phase 1 backend environment variables. On Railway, set these under each
# service's "Variables" tab (or as shared "Reference Variables" if using
# Railway's Postgres/Redis plugins, which auto-populate DATABASE_URL /
# REDIS_URL for you - see the deployment notes in backend/README.md).

# --- Existing pipeline settings (same as the root .env.example) ---
BIBLIO_CONTACT_EMAIL=you@example.com
NCBI_API_KEY=
OPENALEX_API_KEY=

# --- Database (Railway's Postgres plugin injects DATABASE_URL automatically) ---
DATABASE_URL=sqlite:///./jarvis_scholar.db

# --- Job queue (Railway's Redis plugin injects REDIS_URL automatically) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage: "local" for dev, "s3" for anything durable in production ---
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage_data

# Only needed when STORAGE_BACKEND=s3. Works with real AWS S3 (leave
# S3_ENDPOINT_URL blank) or any S3-compatible store like Cloudflare R2 /
# Backblaze B2 / Supabase Storage (set S3_ENDPOINT_URL to that provider's
# S3-compatible endpoint).
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Reject uploads bigger than this many rows in a single job (protects the
# free/shared-tier worker from one runaway multi-day job)
JARVIS_MAX_ROWS=20000
