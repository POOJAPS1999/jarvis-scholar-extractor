# Copy this to .env.scopus and fill in your real values.
# .env.scopus should NEVER be committed to GitHub or shared publicly.
# This is completely separate from the main pipeline's .env - the Scopus
# gap-filler is a standalone script and does not touch bibliometric_pipeline's
# own config at all.

# Required: register at https://dev.elsevier.com/apikey/manage
# Works when called from your institution's network/IP range.
SCOPUS_API_KEY=

# Optional: only needed if you're calling this from OFF your institution's
# network (home, personal laptop off VPN) and your library has issued you
# an Institutional Token for remote Scopus API access. Leave blank if
# you're on-campus or on your institution's VPN.
SCOPUS_INST_TOKEN=

# Used for a polite User-Agent header only - not sent to Elsevier as auth.
SCOPUS_CONTACT_EMAIL=your_email@example.com
