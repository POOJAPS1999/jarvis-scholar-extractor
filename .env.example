# Copy this file to .env and fill in your real values.
# .env should NEVER be committed to GitHub or shared publicly.

# Required: used as the "polite pool" contact for OpenAlex/PubMed/Crossref.
# Use a dedicated project email if this tool will ever be used by others.
BIBLIO_CONTACT_EMAIL=your_email@example.com

# Optional but recommended: raises your NCBI rate limit from 3 to 10 req/s.
# Get a free key at https://www.ncbi.nlm.nih.gov/account/settings/
# IMPORTANT: if a key was ever pasted into a chat, code file, or public repo,
# treat it as compromised and generate a new one.
NCBI_API_KEY=

# Strongly recommended if you have ANY records without a DOI: OpenAlex now
# runs on a daily usage budget ($0.10/day anonymous, $1/day - 10x more -
# with a free key). DOI-based lookups are unlimited even without a key, but
# title-search (used for every no-DOI record) is budget-limited and the
# anonymous budget runs out fast on title-heavy batches. Free account + key
# at https://openalex.org/settings/api (takes about 30 seconds).
OPENALEX_API_KEY=

# File paths (defaults to your Desktop if not set)
BIBLIO_INPUT_FILE=~/Desktop/publications.xlsx
BIBLIO_OUTPUT_FILE=~/Desktop/bibliometric_output.xlsx
BIBLIO_CHECKPOINT_FILE=~/Desktop/bibliometric_checkpoint.csv

# Two-tier fuzzy match thresholds (0-100)
BIBLIO_FUZZY_AUTO_ACCEPT=85
BIBLIO_FUZZY_REVIEW_MIN=75

# How many times to auto-retry a record whose source fetch failed
# transiently (timeout/rate-limit/5xx) before giving up and flagging it
# for manual review instead of retrying forever.
BIBLIO_MAX_FETCH_RETRIES=3

# Best-effort acknowledgment text via PMC full text (only works for
# records with a PMCID in PMC's open-access subset; most records will
# still come back empty). Adds one extra sequential API call per record,
# so it slows the run down - off by default.
BIBLIO_FETCH_ACKNOWLEDGMENT=false

# Comma-separated list of optional output-column groups to turn on (core
# columns are always present regardless of this setting). Available:
#   icmr_flags            - First/Corresponding/Any Author from ICMR (Yes/No), Intramural/Extramural
#   icmr_institute         - ICMR Institute (Current Name): which of ICMR's 28
#                            constituent institutes an ICMR-affiliated record
#                            belongs to, tagged with the institute's current
#                            official name even if the paper used an old name
#   institution_details    - INSTITUTE, DIVISION, Institution Type, Collaboration Type, Collaborators
#   journal_metrics        - Impact Factor, CiteScore, SJR, SNIP, WoS/Scopus indexing + quartile, Rank
#   research_classification - HEALTH IMPACT, Domains, Micro Domains, 4Ds Framework
#   extra_bibliometric     - Country, Subject Category
#   qc_notes               - Comments
# Example (an ICMR-institute-style run):
# BIBLIO_OPTIONAL_COLUMN_GROUPS=icmr_flags,icmr_institute,institution_details
BIBLIO_OPTIONAL_COLUMN_GROUPS=
